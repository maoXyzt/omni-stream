[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true

[*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,vue,css,scss,sass,less,styl}]
indent_size = 2
insert_final_newline = true
max_line_length = 100

[*.{md}]
indent_size = 2
insert_final_newline = true
max_line_length = 100

[*.{rs}]
indent_size = 2
insert_final_newline = true
max_line_length = 100

[*.{toml}]
indent_size = 2
insert_final_newline = true
max_line_length = 100
